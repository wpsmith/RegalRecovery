    "God, grant me the serenity to accept the things I cannot change, courage to change the things I can, and wisdom to know the difference.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dios, concédeme la serenidad para aceptar las cosas que no puedo cambiar, valor para cambiar las que puedo, y sabiduría para conocer la diferencia."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieu, accorde-moi la sérénité d'accepter les choses que je ne peux pas changer, le courage de changer celles que je peux, et la sagesse d'en connaître la différence."
          }
        }
      }
    },
